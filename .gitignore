# ==========================================================
# PYTHON
# ==========================================================

__pycache__/
*.py[cod]
*$py.class

# ==========================================================
# VIRTUAL ENVIRONMENTS
# ==========================================================

.venv/
venv/
env/
ENV/

# ==========================================================
# ENVIRONMENT VARIABLES
# ==========================================================

.env

# ==========================================================
# PYTHON TOOLS
# ==========================================================

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ==========================================================
# IDE
# ==========================================================

.vscode/
.idea/

# ==========================================================
# OPERATING SYSTEM
# ==========================================================

.DS_Store
Thumbs.db
desktop.ini

# ==========================================================
# LOGS
# ==========================================================

*.log
storage/logs/*

!storage/logs/
!storage/logs/.gitkeep

# ==========================================================
# TEMP FILES
# ==========================================================

storage/temp/*

!storage/temp/
!storage/temp/.gitkeep

# ==========================================================
# BACKUPS
# ==========================================================

storage/backup/*

!storage/backup/
!storage/backup/.gitkeep

# ==========================================================
# GENERATED OUTPUT
# ==========================================================

storage/output/*

!storage/output/
!storage/output/.gitkeep

# ==========================================================
# HOTEL DATA (PRIVATE)
# ==========================================================

# Mantener la estructura de carpetas
!storage/input/
!storage/input/excels/
!storage/input/pdfs/

# Mantener los archivos .gitkeep
!storage/input/excels/.gitkeep
!storage/input/pdfs/.gitkeep

# Ignorar todos los datos importados
storage/input/excels/*
storage/input/pdfs/*

# ==========================================================
# TEMPLATES (VERSIONADAS)
# ==========================================================

# Las plantillas forman parte del proyecto
!storage/templates/
!storage/templates/**

# ==========================================================
# REGISTRY (VERSIONADO)
# ==========================================================

# Mantener el registro del sistema
!storage/registry/
!storage/registry/imported_deliveries.json

# ==========================================================
# DOCUMENTATION (Opcional)
# ==========================================================

# *.pdf